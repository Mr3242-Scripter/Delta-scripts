    "contact",
    "every script i created rests in peace here",
    "rayfield made by sirius"
}

local function isBlocked(name)
    local n = tostring(name or ""):lower()

    for _, bad in ipairs(blacklist) do
        if n:find(tostring(bad):lower(), 1, true) then
            return true
        end
    end

    return false
end

--// FETCH SCRIPTS
local function getScripts()
    local scripts = {}

    local ok, html = pcall(function()
        return game:HttpGet(PROFILE_URL)
    end)

    if not ok or type(html) ~= "string" then
        return scripts
    end

    -- slightly safer pattern
    for id, name in html:gmatch('href="/(%w+)"[^>]*>([^<]+)</a>') do
        name = clean(name)

        if name ~= "" and not isBlocked(name) then
            table.insert(scripts, {
                name = name,
                url = toRaw(id)
            })
        end
    end

    table.sort(scripts, function(a, b)
        return tostring(a.name):lower() < tostring(b.name):lower()
    end)

    return scripts
end

