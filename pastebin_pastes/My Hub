    pcall(function()
        loadstring(game:HttpGet(url))()
    end)
end

local function toRaw(id)
    return "https://pastebin.com/raw/" .. tostring(id)
end

local function clean(text)
    text = text or ""
    text = text:gsub("&amp;", "&")
    text = text:gsub("<.->", "")
    text = text:gsub("%s+", " ")
    text = text:gsub("^%s+", ""):gsub("%s+$", "")
    return text
end

