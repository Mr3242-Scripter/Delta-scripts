--// NOTIFY WRAPPER
local oldNotify = Rayfield.Notify

if typeof(oldNotify) ~= "function" then
    oldNotify = function() end
end

Rayfield.Notify = function(self, data)
    if data and data.Title then
        local t = tostring(data.Title)
        if t:lower():find("rayfield") or t:lower():find("interface") then return end
    end
    return oldNotify(self, data)
end

local function Notify(t, c)
    pcall(function()
        Rayfield:Notify({
            Title = tostring(t),
            Content = tostring(c),
            Duration = 3,
            Image = 4483362458
        })
    end)
end

